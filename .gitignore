# ─────────────────────────────────────────────────────────────
# HelioNest-AI .gitignore
# ─────────────────────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.pem
*.key

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
dist/
build/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.pyc

# ── Pytest / Coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Alembic ───────────────────────────────────────────────────
# (keep versions directory but ignore __pycache__)
backend/alembic/__pycache__/

# ── Node / Next.js ────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── ChromaDB / Vector store ───────────────────────────────────
ai/embeddings/chroma_db/
*.chroma

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ── Docker volumes (local) ────────────────────────────────────
postgres_data/
redis_data/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
