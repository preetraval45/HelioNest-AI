# ─────────────────────────────────────────────────────────────
# HelioNest-AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://helionest:helionest@localhost:5432/helionest_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI — Anthropic ────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Geocoding ─────────────────────────────────────────────────
# Geocodio: https://www.geocod.io/ (free tier: 2,500/day)
GEOCODIO_API_KEY=

# ── Solar ─────────────────────────────────────────────────────
# NREL Developer Network: https://developer.nrel.gov/signup/
NREL_API_KEY=

# ── Maps ──────────────────────────────────────────────────────
# Mapbox: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=
# Also needed on frontend:
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Air Quality (Phase 3) ────────────────────────────────────
# OpenAQ: https://docs.openaq.org/ (no key needed for v2)
# IQAir (optional): https://www.iqair.com/dashboard/api
OPENAQ_API_KEY=

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Monitoring (Phase 3) ─────────────────────────────────────
# Sentry: https://sentry.io/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Analytics (Phase 3) ──────────────────────────────────────
# PostHog: https://app.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
